# ------------------------------------------------------------
# Clerk authentication (https://clerk.com — free tier)
# 1. Create an application at dashboard.clerk.com
# 2. Copy the Publishable key and Secret key from API Keys
# 3. (Optional) Set up a webhook -> /api/webhooks/clerk and copy its signing secret
# The app runs fine with these empty; auth screens simply won't work until set.
# ------------------------------------------------------------
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=

# ------------------------------------------------------------
# AI Analyst (Google Gemini free tier — https://aistudio.google.com/apikey)
# AI_PROVIDER can be "gemini" (default), "groq", or "openai" so the key can be
# swapped without code changes.
# ------------------------------------------------------------
AI_PROVIDER=gemini
AI_API_KEY=